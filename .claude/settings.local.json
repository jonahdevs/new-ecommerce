{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__search-docs",
      "mcp__laravel-boost__browser-logs",
      "mcp__laravel-boost__database-query",
      "PowerShell($r = Invoke-WebRequest -Uri \"https://new-ecommerce.test\" -SkipCertificateCheck -ErrorAction SilentlyContinue; \"Status: $\\($r.StatusCode\\)\"; \"Length: $\\($r.Content.Length\\)\")",
      "PowerShell(php artisan test --compact --filter='HomePage|home page' 2>&1 | Select-Object -Last 25)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
